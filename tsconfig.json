{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@rfdtech/components": ["./src/index.ts"],
      "demo/*": ["./demo/*"]
    }
  },
  "include": ["src", "demo"],
  "exclude": ["node_modules", "dist", "src/adapters/next-adapter.tsx", "src/next-index.ts"]
}
