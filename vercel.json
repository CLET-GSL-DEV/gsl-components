{
  "buildCommand": "npm run build:demo",
  "outputDirectory": "demo/dist/client",
  "installCommand": "npm install",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "demo/dist/**"
    }
  },
  "rewrites": [
    { "source": "/docs", "destination": "/api/ssr" },
    { "source": "/docs/(.*)", "destination": "/api/ssr" }
  ]
}
